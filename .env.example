# Root-level example. Copy individual files into backend/ and frontend/ —
# this file documents what each one needs.

# ---- backend/.env ----
# PORT=8000
# DB_FILE=db/dev.db                            # dev only (SQLite)
# DATABASE_URL=postgres://...                  # prod (Render Postgres)
# SCHEMA=socialstake_schema                    # prod (Sequelize schema namespace)
# JWT_SECRET=<long-random-string>
# JWT_EXPIRES_IN=604800
# NODE_ENV=development                         # set to "production" on Render
# REACT_APP_BACKEND_PROD_URL=https://<your-vercel-frontend-url>
#   ^ NOTE: misnamed historically — this is the allowed CLIENT origin for
#     socket.io CORS in production. Set it to your Vercel URL, not the
#     backend URL.
# AWS_ACCESS_KEY_ID=<rotate before deploy>
# AWS_SECRET_ACCESS_KEY=<rotate before deploy>

# ---- frontend/.env ----
# REACT_APP_BACKEND_PROD_URL=https://<your-render-backend-url>
#   ^ Used by SocketContext + csrf middleware to point at the prod API.
