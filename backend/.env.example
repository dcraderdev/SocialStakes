# ---- backend/.env (dev) ----
PORT=8000
DB_FILE=db/dev.db
JWT_SECRET=replace-me-with-long-random-string
JWT_EXPIRES_IN=604800

# Only used in production (Render). Misnamed historically: this is the allowed
# socket.io CLIENT origin, not the backend URL. Point it at your Vercel URL.
REACT_APP_BACKEND_PROD_URL=https://your-vercel-frontend.vercel.app

# Rotate these before any public deploy.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- production overrides (set in Render dashboard, not in repo) ----
# NODE_ENV=production
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# SCHEMA=socialstake_schema
